APP_NAME=LandingPage
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
TRUSTED_HOSTS=localhost

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Uzi pilot config
OIDC_ISSUER=https://localhost:8006
OIDC_CLIENT_ID=37692967-0a74-4e91-85ec-a4250e7ad5e8
OIDC_DECRYPTION_KEY_PATH=../secrets/nl-uzipoc-php-laravel-demo.key
OIDC_TLS_VERIFY=false
DIGID_MOCK_ENABLED=true

# Timeline service config
TIMELINE_ENDPOINT=http://timeline:8505
ADDRESSING_ENDPOINT=http://hapi-metadata-addressing:8513/fhir
